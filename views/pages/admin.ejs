      </div>
      <div class="stat-card">
        <div class="stat-card-icon yellow">🔄</div>
        <div>
          <div class="stat-card-val">412</div>
          <div class="stat-card-lbl">Subscription Đang Hoạt Động</div>
          <div class="stat-card-trend up">↑ +34 đăng ký mới</div>
        </div>
      </div>
    </div>

    <!-- Revenue Chart + Recent Orders -->
    <div class="grid-2">
      <!-- Chart -->
      <div class="admin-card">
        <div class="card-header">
          <span class="card-title">📈 Doanh Thu 7 Ngày Qua</span>
          <span class="card-badge">Tháng 4/2025</span>
        </div>
        <div class="chart-bars" id="revenue-chart"></div>
      </div>

      <!-- Top products -->
      <div class="admin-card">
        <div class="card-header">
          <span class="card-title">🏆 Sản Phẩm Bán Chạy</span>
