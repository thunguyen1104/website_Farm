<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Admin Dashboard – NaFarm</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

<!-- Nav -->
<nav class="nav scrolled" style="z-index:200">
  <div class="nav-inner">
    <a href="/" class="logo">
      <div class="logo-mark">🌿</div>
      <div class="logo-text"><span class="brand">NaFarm</span><span class="tagline">Admin Dashboard</span></div>
    </a>
    <div class="nav-actions">
      <div style="font-size:.82rem;color:var(--text-secondary);font-weight:700" id="admin-user-info">👨‍💼 Admin</div>
    </div>
  </div>
</nav>

<div class="admin-layout">
  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div style="color:#fff;font-weight:800;font-size:1rem">🌿 NaFarm Admin</div>
      <p>Quản Trị Hệ Thống</p>
    </div>
    <nav class="sidebar-nav">
      <div class="s-section">Tổng Quan</div>
      <button class="s-link active" data-panel="dashboard">Dashboard</button>

      <div class="s-section">Quản Lý</div>
      <button class="s-link" data-panel="products">Sản Phẩm <span class="s-badge" id="sb-prod">12</span></button>
      <button class="s-link" data-panel="orders">Đơn Hàng <span class="s-badge" id="sb-orders">0</span></button>
      <button class="s-link" data-panel="categories">Danh Mục</button>
      <button class="s-link" data-panel="customers">Khách Hàng</button>

      <div class="s-section">Báo Cáo</div>
      <button class="s-link" data-panel="analytics">Thống Kê</button>

      <div class="s-section">Hệ Thống</div>
      <button class="s-link" data-panel="settings">Cài Đặt</button>
    </nav>
    <div style="padding:16px;border-top:1px solid rgba(255,255,255,.1)">
      <div style="font-size:.72rem;color:rgba(255,255,255,.4);text-align:center">NaFarm v4.0 · Admin</div>
    </div>
  </aside>

  <!-- Main -->
  <main class="admin-main">

    <!-- ══ DASHBOARD ══ -->
    <div class="admin-panel active" id="panel-dashboard">
      <div class="admin-topbar">
        <div>
          <h1>Dashboard</h1>
          <p>Chào mừng trở lại! Hôm nay là <span id="today-date"></span></p>
        </div>
        <div class="topbar-actions">
          <button class="btn btn-primary" onclick="switchPanel('orders')">+ Xem Đơn Hàng</button>
        </div>
      </div>
      <div class="stats-grid" id="dash-stats"></div>
      <div class="grid-2">
        <!-- Revenue chart -->
        <div class="admin-card">
          <div class="card-header">
            <div class="card-title">📈 Doanh Thu 7 Ngày</div>
            <span class="card-badge">Tháng 4/2025</span>
          </div>
          <div class="chart-bars" id="rev-chart"></div>
        </div>
        <!-- Recent orders -->
        <div class="admin-card">
          <div class="card-header">
            <div class="card-title">🛍️ Đơn Hàng Gần Đây</div>
            <button class="btn btn-ghost" style="font-size:.78rem;padding:5px 12px" onclick="switchPanel('orders')">Xem Tất Cả</button>
          </div>
          <div class="o-list" id="recent-orders-list"></div>
        </div>
      </div>
      <!-- Top Products -->
      <div class="admin-card" style="margin-top:0">
        <div class="card-header">
          <div class="card-title">🏆 Sản Phẩm Bán Chạy</div>
          <button class="btn btn-ghost" style="font-size:.78rem;padding:5px 12px" onclick="switchPanel('products')">Quản Lý</button>
        </div>
        <table class="admin-table" id="top-prods-table"></table>
      </div>
    </div>

    <!-- ══ PRODUCTS ══ -->
    <div class="admin-panel" id="panel-products">
      <div class="admin-topbar">
        <div><h1>Quản Lý Sản Phẩm</h1><p>Thêm, sửa, xóa sản phẩm trong hệ thống</p></div>
        <div class="topbar-actions">
          <button class="btn btn-primary" id="btn-add-product">+ Thêm Sản Phẩm</button>
        </div>
      </div>
      <div class="search-filter-bar">
        <input type="text" id="prod-search" placeholder="🔍 Tìm tên sản phẩm, nguồn gốc..."/>
        <select id="prod-cat-filter">
          <option value="">Tất cả danh mục</option>
          <option value="say-deo">Sấy Dẻo</option>
          <option value="say-gion">Sấy Giòn</option>
          <option value="hat">Hạt & Ngũ Cốc</option>
          <option value="tuoi">Trái Tươi</option>
          <option value="tra">Trà & Thức Uống</option>
        </select>
        <select id="prod-stock-filter">
          <option value="">Tất cả tồn kho</option>
          <option value="ok">Còn hàng (≥20)</option>
          <option value="low">Sắp hết (10–19)</option>
          <option value="out">Hết hàng (&lt;10)</option>
        </select>
      </div>
      <div class="admin-card" style="padding:0;overflow:hidden">
        <table class="admin-table" id="products-table">
          <thead>
            <tr>
              <th>Sản Phẩm</th><th>Danh Mục</th><th>Giá Bán</th><th>Tồn Kho</th><th>Đánh Giá</th><th>Trạng Thái</th><th>Thao Tác</th>
            </tr>
          </thead>
          <tbody id="products-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- ══ ORDERS ══ -->
    <div class="admin-panel" id="panel-orders">
      <div class="admin-topbar">
        <div><h1>Quản Lý Đơn Hàng</h1><p>Xem và cập nhật trạng thái đơn hàng</p></div>
        <div class="topbar-actions">
          <button class="btn btn-ghost" id="btn-export-orders"> Xuất CSV</button>
        </div>
      </div>
      <div class="admin-tabs" id="order-tabs">
        <button class="admin-tab active" data-status="all">Tất cả <span class="badge-count blue" id="cnt-all">0</span></button>
        <button class="admin-tab" data-status="processing">Chờ xử lý <span class="badge-count yellow" id="cnt-proc">0</span></button>
        <button class="admin-tab" data-status="shipped">Đang giao <span class="badge-count blue" id="cnt-ship">0</span></button>
        <button class="admin-tab" data-status="done">Đã giao <span class="badge-count green" id="cnt-done">0</span></button>
        <button class="admin-tab" data-status="cancelled">Đã hủy <span class="badge-count red" id="cnt-cancel">0</span></button>
      </div>
      <div class="search-filter-bar">
        <input type="text" id="order-search" placeholder="🔍 Tìm mã đơn, tên KH, sản phẩm..."/>
      </div>
      <div class="admin-card" style="padding:0;overflow:hidden">
        <table class="admin-table">
          <thead>
            <tr><th>Mã Đơn</th><th>Sản Phẩm</th><th>Tổng Tiền</th><th>Thanh Toán</th><th>Ngày Đặt</th><th>Trạng Thái</th><th>Thao Tác</th></tr>
          </thead>
          <tbody id="orders-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- ══ CATEGORIES ══ -->
    <div class="admin-panel" id="panel-categories">
      <div class="admin-topbar">
        <div><h1>Quản Lý Danh Mục</h1><p>Thêm và quản lý danh mục sản phẩm</p></div>
        <div class="topbar-actions">
          <button class="btn btn-primary" id="btn-add-cat">+ Thêm Danh Mục</button>
        </div>
      </div>
      <div id="cat-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:18px"></div>
    </div>

    <!-- ══ CUSTOMERS ══ -->
    <div class="admin-panel" id="panel-customers">
      <div class="admin-topbar">
        <div><h1>Khách Hàng</h1><p>Danh sách khách hàng đã đặt hàng</p></div>
      </div>
      <div class="admin-card" style="padding:0;overflow:hidden">
        <table class="admin-table">
          <thead><tr><th>#</th><th>Tên / Email</th><th>Số Đơn</th><th>Tổng Chi Tiêu</th><th>Đơn Gần Nhất</th><th>Thao Tác</th></tr></thead>
          <tbody id="customers-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- ══ ANALYTICS ══ -->
    <div class="admin-panel" id="panel-analytics">
      <div class="admin-topbar"><div><h1>Thống Kê</h1><p>Báo cáo doanh thu và hoạt động</p></div></div>
      <div class="stats-grid" id="analytics-stats"></div>
      <div class="grid-2" style="margin-top:0">
        <div class="admin-card">
          <div class="card-header"><div class="card-title">🏆 Top 5 Sản Phẩm Bán Chạy</div></div>
          <div id="top5-list"></div>
        </div>
        <div class="admin-card">
          <div class="card-header"><div class="card-title">💳 Phương Thức Thanh Toán</div></div>
          <div id="payment-chart"></div>
        </div>
      </div>
    </div>

    <!-- ══ SETTINGS ══ -->
    <div class="admin-panel" id="panel-settings">
      <div class="admin-topbar"><div><h1>Cài Đặt</h1><p>Cấu hình hệ thống NaFarm</p></div></div>
      <div class="grid-2" style="margin-top:0">
        <div class="checkout-section">
          <h3>Thông Tin Cửa Hàng</h3>
          <div class="form-group"><label>Tên cửa hàng</label><input value="NaFarm – Đặc Sản Việt Nam"/></div>
          <div class="form-group"><label>Hotline</label><input value="1800-NaFarm"/></div>
          <div class="form-group"><label>Email</label><input value="hello@nafarm.vn"/></div>
          <div class="form-group"><label>Địa chỉ kho</label><input value="12 Nguyễn Văn Cừ, Q.5, TP.HCM"/></div>
          <button class="btn btn-primary">Lưu Thay Đổi</button>
        </div>
        <div class="checkout-section">
          <h3>Cấu Hình Vận Chuyển</h3>
          <div class="form-group"><label>Miễn phí ship từ (đ)</label><input type="number" value="300000"/></div>
          <div class="form-group"><label>Phí ship tiêu chuẩn (đ)</label><input type="number" value="30000"/></div>
          <div class="form-group"><label>Phí ship hỏa tốc (đ)</label><input type="number" value="29000"/></div>
          <div class="form-group">
            <label>Đơn vị vận chuyển mặc định</label>
            <select><option>GHN Express</option><option>GHTK</option><option>ViettelPost</option><option>VNPost</option></select>
          </div>
          <button class="btn btn-primary">Lưu Thay Đổi</button>
        </div>
      </div>
    </div>

  </main>
</div>

<!-- Product Modal -->
<div class="modal-overlay" id="prod-modal">
  <div class="modal-box">
    <h3 id="prod-modal-title">📦 Thêm Sản Phẩm Mới</h3>
    <div class="product-form-grid">
      <div class="form-group"><label>Tên sản phẩm *</label><input id="pf-name" placeholder="Xoài Sấy Dẻo Đà Lạt"/></div>
      <div class="form-group">
        <label>Emoji</label>
        <input id="pf-emoji" placeholder="🥭" style="font-size:1.2rem;text-align:center"/>
      </div>
      <div class="form-group"><label>Giá bán (đ) *</label><input id="pf-price" type="number" placeholder="85000"/></div>
      <div class="form-group"><label>Giá gốc (đ, nếu có sale)</label><input id="pf-old" type="number" placeholder="110000"/></div>
      <div class="form-group"><label>Danh mục *</label>
        <select id="pf-cat">
          <option value="say-deo">Sấy Dẻo</option>
          <option value="say-gion">Sấy Giòn</option>
          <option value="hat">Hạt & Ngũ Cốc</option>
          <option value="tuoi">Trái Tươi</option>
          <option value="tra">Trà & Thức Uống</option>
        </select>
      </div>
      <div class="form-group"><label>Nguồn gốc *</label><input id="pf-origin" placeholder="Đà Lạt"/></div>
      <div class="form-group"><label>Tồn kho *</label><input id="pf-stock" type="number" placeholder="50"/></div>
      <div class="form-group"><label>Badge</label>
        <select id="pf-badge">
          <option value="hot">Hot</option><option value="new">Mới</option>
          <option value="sale">Giảm Giá</option><option value="organic">Organic</option>
        </select>
      </div>
    </div>
    <div class="form-group"><label>Mô tả *</label><textarea id="pf-desc" rows="2" placeholder="Mô tả ngắn về sản phẩm..."></textarea></div>
    <div class="form-group"><label>Câu chuyện nguồn gốc</label><textarea id="pf-story" rows="2" placeholder="Hành trình từ nông trại đến bàn ăn..."></textarea></div>
    <div class="form-group"><label>Tags (phân cách bằng dấu phẩy)</label><input id="pf-tags" placeholder="Vitamin C, Organic, Không đường"/></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeProdModal()">Hủy</button>
      <button class="btn btn-primary" id="btn-save-product">💾 Lưu Sản Phẩm</button>
    </div>
  </div>
</div>

<!-- Order Detail Modal -->
<div class="modal-overlay" id="order-modal">
  <div class="modal-box" style="max-width:620px">
    <h3>📋 Chi Tiết Đơn Hàng</h3>
    <div id="order-detail-content"></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeOrderModal()">Đóng</button>
      <button class="btn btn-primary" id="btn-update-status">Cập Nhật Trạng Thái</button>
    </div>
  </div>
</div>

<!-- Category Modal -->
<div class="modal-overlay" id="cat-modal">
  <div class="modal-box" style="max-width:500px">
    <h3 id="cat-modal-title">🎯 Thêm Danh Mục Mới</h3>
    <div class="form-group"><label>Tên Danh Mục *</label><input id="cf-name" placeholder="VD: Trái Cây Sấy Dẻo"/></div>
    <div class="form-group"><label>Emoji Đại Diện *</label><input id="cf-emoji" placeholder="🥭" style="font-size:1.2rem;text-align:center" maxlength="2"/></div>
    <div class="form-group"><label>Slug (ID) *</label><input id="cf-slug" placeholder="say-deo" readonly style="background:var(--gray-100)"/></div>
    <div class="form-group"><label>Mô Tả *</label><textarea id="cf-desc" rows="3" placeholder="Mô tả ngắn về danh mục..."></textarea></div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeCatModal()">Hủy</button>
      <button class="btn btn-primary" id="btn-save-category">💾 Lưu Danh Mục</button>
    </div>
  </div>
</div>

<div class="toast-tray"></div>

<script>
(function(){
'use strict';
function loadLS(k,d){try{const v=localStorage.getItem('nf_'+k);return v?JSON.parse(v):d;}catch(e){return d;}}
function saveLS(k,v){try{localStorage.setItem('nf_'+k,JSON.stringify(v));}catch(e){}}
const vnd=n=>n.toLocaleString('vi-VN')+'đ';
function toast(msg,type=''){const tray=document.querySelector('.toast-tray');if(!tray)return;const el=document.createElement('div');el.className='toast'+(type?' '+type:'');el.textContent=msg;tray.appendChild(el);setTimeout(()=>el.style.opacity='0',2900);setTimeout(()=>el.remove(),3300);}

const PRODUCTS_BASE=[
  {id:1,name:'Xoài Sấy Dẻo Đà Lạt',e:'🥭',price:85000,old:110000,badges:['sale'],origin:'Đà Lạt',cat:'say-deo',r:4.8,rv:124,stock:56,desc:'Ngọt tự nhiên, không phẩm màu.',tags:['Không đường','Vitamin C'],story:'Thu hoạch từ vườn xoài 20 năm tuổi.'},
  {id:2,name:'Dâu Tây Sấy Giòn',e:'🍓',price:92000,badges:['new'],origin:'Đà Lạt',cat:'say-gion',r:4.9,rv:89,stock:32,desc:'Giòn tan, chua ngọt tự nhiên.',tags:['Organic','Vitamin C'],story:'Dâu tây hái buổi sáng sớm.'},
  {id:3,name:'Hạt Điều Rang Muối',e:'🥜',price:145000,badges:['hot'],origin:'Bình Phước',cat:'hat',r:4.7,rv:201,stock:98,desc:'Rang tay, giòn đều và thơm.',tags:['Protein','Không GMO'],story:'Điều thô hữu cơ từ Bình Phước.'},
  {id:4,name:'Chuối Sấy Dẻo Tiền Giang',e:'🍌',price:65000,old:85000,badges:['sale'],origin:'Tiền Giang',cat:'say-deo',r:4.6,rv:156,stock:45,desc:'Dẻo mềm, đậm đà vị ngọt.',tags:['Kali','Năng lượng'],story:'Chuối sứ chín 100% trên cây.'},
  {id:5,name:'Trái Cây Tươi Mix Đà Lạt',e:'🍒',price:180000,badges:['new'],origin:'Đà Lạt',cat:'tuoi',r:5.0,rv:67,stock:12,desc:'Hộp 5–7 loại, hái sáng giao chiều.',tags:['Tươi ngày','Organic'],story:'Đặt trước 10h, giao trong ngày.'},
  {id:6,name:'Óc Chó Hữu Cơ California',e:'🫘',price:220000,badges:['organic'],origin:'USA',cat:'hat',r:4.8,rv:93,stock:27,desc:'Omega-3, USDA Organic.',tags:['Omega-3','USDA Organic'],story:'Nhập từ Sacramento Valley, CA.'},
  {id:7,name:'Kiwi Sấy Giòn New Zealand',e:'🥝',price:115000,badges:['new'],origin:'New Zealand',cat:'say-gion',r:4.7,rv:78,stock:41,desc:'Chua ngọt hài hòa.',tags:['Vitamin C','Chất xơ'],story:'Kiwi Zespri SunGold.'},
  {id:8,name:'Trà Atiso Đà Lạt',e:'🌺',price:78000,badges:['new'],origin:'Đà Lạt',cat:'tra',r:4.9,rv:142,stock:89,desc:'Thanh lọc cơ thể, mát gan.',tags:['Giải độc','Mát gan'],story:'Atiso phơi sấy tự nhiên.'},
  {id:9,name:'Bơ Sấy Giòn Đắk Lắk',e:'🥑',price:95000,old:120000,badges:['sale'],origin:'Đắk Lắk',cat:'say-gion',r:4.6,rv:88,stock:63,desc:'Béo bùi tự nhiên.',tags:['Omega-9','Béo lành'],story:'Bơ 034 thu hoạch đúng độ chín.'},
  {id:10,name:'Hạt Macadamia Úc',e:'🌰',price:285000,badges:['organic'],origin:'Australia',cat:'hat',r:4.9,rv:112,stock:19,desc:'Bùi béo, từ Queensland.',tags:['Omega-7','Premium'],story:'Thu hoạch thủ công Queensland.'},
  {id:11,name:'Táo Sấy Dẻo Đà Lạt',e:'🍏',price:72000,badges:['hot'],origin:'Đà Lạt',cat:'say-deo',r:4.5,rv:64,stock:74,desc:'Táo Anna Đà Lạt sấy dẻo.',tags:['Pectin','Vitamin A'],story:'Táo Anna vùng cao Đà Lạt.'},
  {id:12,name:'Trà Ô Long Bảo Lộc',e:'🍵',price:88000,badges:['new'],origin:'Lâm Đồng',cat:'tra',r:4.8,rv:99,stock:51,desc:'Ô long thượng hạng.',tags:['Polyphenol','Cao cấp'],story:'Hái tay từ đồi trà 50 năm.'},
];
const CATEGORIES=[
  {id:'say-deo',name:'Sấy Dẻo',e:'🥭',desc:'Trái cây sấy mềm dẻo, giữ nguyên hương vị tự nhiên'},
  {id:'say-gion',name:'Sấy Giòn',e:'🍓',desc:'Giòn tan, chua ngọt, ăn vặt lành mạnh mỗi ngày'},
  {id:'hat',name:'Hạt & Ngũ Cốc',e:'🌰',desc:'Hạt nội địa & nhập khẩu, giàu protein và omega'},
  {id:'tuoi',name:'Trái Tươi Việt Nam',e:'🍒',desc:'Hái sáng giao chiều, đảm bảo tươi ngon tuyệt đối'},
  {id:'tra',name:'Trà & Thức Uống',e:'🍵',desc:'Trà thảo mộc, trà ô long cao cấp từ vùng cao Việt Nam'},
];

// State
let products = loadLS('admin_products', PRODUCTS_BASE);
let orders   = loadLS('orders', []);
let editProdId = null, editOrderId = null, editCatId = null;
let orderFilter = 'all';

// Update badge counts
function updateSidebar(){
  orders = loadLS('orders',[]);
  document.getElementById('sb-prod').textContent = products.length;
  document.getElementById('sb-orders').textContent = orders.length;
}

// Panel switching
window.switchPanel = function(id){
  document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.s-link').forEach(l=>l.classList.remove('active'));
  document.getElementById('panel-'+id)?.classList.add('active');
  document.querySelector(`.s-link[data-panel="${id}"]`)?.classList.add('active');
  if(id==='dashboard') renderDashboard();
  if(id==='products') renderProducts();
  if(id==='orders') renderOrders();
  if(id==='categories') renderCategories();
  if(id==='customers') renderCustomers();
  if(id==='analytics') renderAnalytics();
};
document.querySelectorAll('.s-link[data-panel]').forEach(b=>b.addEventListener('click',()=>switchPanel(b.dataset.panel)));

// ── DASHBOARD ────────────────────────────────────────
function renderDashboard(){
  orders=loadLS('orders',[]);
  document.getElementById('today-date').textContent=new Date().toLocaleDateString('vi-VN',{weekday:'long',day:'2-digit',month:'2-digit',year:'numeric'});
  const totalRev=orders.filter(o=>o.status==='done').reduce((s,o)=>s+o.total,0);
  const pending=orders.filter(o=>o.status==='processing').length;
  const shipped=orders.filter(o=>o.status==='shipped').length;
  document.getElementById('dash-stats').innerHTML=`
    <div class="stat-card"><div class="stat-card-icon green">💰</div><div><div class="stat-card-val">${vnd(totalRev)}</div><div class="stat-card-lbl">Tổng Doanh Thu</div><div class="stat-card-trend up">↑ vs tháng trước</div></div></div>
    <div class="stat-card"><div class="stat-card-icon brown">📦</div><div><div class="stat-card-val">${orders.length}</div><div class="stat-card-lbl">Tổng Đơn Hàng</div><div class="stat-card-trend up">↑ ${pending} đơn mới</div></div></div>
    <div class="stat-card"><div class="stat-card-icon blue">🛍️</div><div><div class="stat-card-val">${products.length}</div><div class="stat-card-lbl">Sản Phẩm</div><div class="stat-card-trend up">↑ Đang hoạt động</div></div></div>
    <div class="stat-card"><div class="stat-card-icon yellow">🚚</div><div><div class="stat-card-val">${shipped}</div><div class="stat-card-lbl">Đang Giao</div><div class="stat-card-trend up">↑ Đang vận chuyển</div></div></div>`;
  // Chart
  const days=['T2','T3','T4','T5','T6','T7','CN'];
  const vals=[12,18,9,25,30,42,15];
  const max=Math.max(...vals);
  document.getElementById('rev-chart').innerHTML=vals.map((v,i)=>`
    <div class="chart-bar-wrap">
      <div class="chart-bar-val">${v}đ</div>
      <div class="chart-bar" style="height:${Math.round(v/max*100)}%" title="${v}tr"></div>
      <div class="chart-bar-lbl">${days[i]}</div>
    </div>`).join('');
  // Recent orders
  const recent=orders.slice(0,5);
  const STATUS_LABEL={processing:'⏳ Xử lý',confirmed:'📋 Xác nhận',shipped:'🚚 Giao',done:'✅ Giao',cancelled:'❌ Hủy'};
  const STATUS_CLS={processing:'proc',confirmed:'proc',shipped:'ship',done:'done',cancelled:'cancel'};
  document.getElementById('recent-orders-list').innerHTML=recent.length?recent.map(o=>`
    <div class="o-item">
      <div class="o-item-id">${o.id}</div>
      <div class="o-item-info"><div class="o-item-name">${o.items.substring(0,30)}${o.items.length>30?'...':''}</div><div class="o-item-date">${o.date}</div></div>
      <div class="o-item-total"><div>${vnd(o.total)}</div><span class="t-status ${STATUS_CLS[o.status]||'proc'}" style="margin-top:4px;display:inline-block">${STATUS_LABEL[o.status]||o.status}</span></div>
    </div>`).join(''):'<div style="text-align:center;padding:20px;color:var(--text-muted)">Chưa có đơn hàng</div>';
  // Top products
  document.getElementById('top-prods-table').innerHTML=`
    <thead><tr><th>#</th><th>Sản Phẩm</th><th>Danh Mục</th><th>Giá</th><th>Tồn Kho</th><th>Đánh Giá</th></tr></thead>
    <tbody>${products.slice(0,5).map((p,i)=>`
      <tr>
        <td><strong>${i+1}</strong></td>
        <td><div class="t-product"><div class="t-emoji">${p.e}</div><div><div class="t-name">${p.name}</div><div class="t-origin">📍 ${p.origin}</div></div></div></td>
        <td>${p.cat}</td>
        <td><strong>${vnd(p.price)}</strong></td>
        <td><span class="t-status ${p.stock<10?'out':p.stock<20?'low':'active'}">${p.stock}</span></td>
        <td>⭐ ${p.r} (${p.rv})</td>
      </tr>`).join('')}</tbody>`;
}

// ── PRODUCTS ─────────────────────────────────────────
function renderProducts(filter='',cat='',stock=''){
  let list=products;
  if(filter)list=list.filter(p=>p.name.toLowerCase().includes(filter)||p.origin.toLowerCase().includes(filter));
  if(cat)list=list.filter(p=>p.cat===cat);
  if(stock==='ok')list=list.filter(p=>p.stock>=20);
  else if(stock==='low')list=list.filter(p=>p.stock>=10&&p.stock<20);
  else if(stock==='out')list=list.filter(p=>p.stock<10);
  document.getElementById('products-tbody').innerHTML=list.map(p=>`
    <tr>
      <td><div class="t-product"><div class="t-emoji">${p.e}</div><div><div class="t-name">${p.name}</div><div class="t-origin">📍 ${p.origin}</div></div></div></td>
      <td><span class="t-status active">${p.cat}</span></td>
      <td><strong>${vnd(p.price)}</strong>${p.old?`<br/><span style="font-size:.72rem;color:var(--text-muted);text-decoration:line-through">${vnd(p.old)}</span>`:''}</td>
      <td><span class="t-status ${p.stock<10?'out':p.stock<20?'low':'active'}">${p.stock<10?'Hết':p.stock<20?'Sắp hết':'Còn'} (${p.stock})</span></td>
      <td>⭐ ${p.r} <span style="color:var(--text-muted);font-size:.72rem">(${p.rv})</span></td>
      <td><span class="t-status ${p.stock>0?'active':'out'}">${p.stock>0?'Đang bán':'Ngừng bán'}</span></td>
      <td style="white-space:nowrap">
        <button class="btn-icon" title="Sửa" onclick="editProduct(${p.id})">✏️</button>
        <button class="btn-icon" title="Xóa" onclick="deleteProduct(${p.id})" style="margin-left:4px">🗑️</button>
      </td>
    </tr>`).join('');
}
document.getElementById('prod-search').addEventListener('input',e=>renderProducts(e.target.value,document.getElementById('prod-cat-filter').value,document.getElementById('prod-stock-filter').value));
document.getElementById('prod-cat-filter').addEventListener('change',e=>renderProducts(document.getElementById('prod-search').value,e.target.value,document.getElementById('prod-stock-filter').value));
document.getElementById('prod-stock-filter').addEventListener('change',e=>renderProducts(document.getElementById('prod-search').value,document.getElementById('prod-cat-filter').value,e.target.value));

document.getElementById('btn-add-product').addEventListener('click',()=>{
  editProdId=null;
  document.getElementById('prod-modal-title').textContent='📦 Thêm Sản Phẩm Mới';
  ['pf-name','pf-emoji','pf-price','pf-old','pf-origin','pf-stock','pf-desc','pf-story','pf-tags'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('prod-modal').classList.add('on');
});
window.editProduct=function(id){
  const p=products.find(x=>x.id===id);if(!p)return;
  editProdId=id;
  document.getElementById('prod-modal-title').textContent='✏️ Sửa Sản Phẩm';
  document.getElementById('pf-name').value=p.name;
  document.getElementById('pf-emoji').value=p.e;
  document.getElementById('pf-price').value=p.price;
  document.getElementById('pf-old').value=p.old||'';
  document.getElementById('pf-cat').value=p.cat;
  document.getElementById('pf-origin').value=p.origin;
  document.getElementById('pf-stock').value=p.stock;
  document.getElementById('pf-badge').value=p.badges?.[0]||'hot';
  document.getElementById('pf-desc').value=p.desc;
  document.getElementById('pf-story').value=p.story||'';
  document.getElementById('pf-tags').value=(p.tags||[]).join(', ');
  document.getElementById('prod-modal').classList.add('on');
};
window.deleteProduct=function(id){
  if(!confirm('Xóa sản phẩm này?'))return;
  products=products.filter(p=>p.id!==id);
  saveLS('admin_products',products);
  renderProducts();updateSidebar();toast('✅ Đã xóa sản phẩm');
};
window.closeProdModal=function(){document.getElementById('prod-modal').classList.remove('on');};
document.getElementById('btn-save-product').addEventListener('click',()=>{
  const name=document.getElementById('pf-name').value.trim();
  const price=+document.getElementById('pf-price').value;
  const stock=+document.getElementById('pf-stock').value;
  if(!name||!price||!stock){toast('⚠️ Điền đủ thông tin bắt buộc','warn');return;}
  const data={
    name,e:document.getElementById('pf-emoji').value||'📦',
    price,old:+document.getElementById('pf-old').value||undefined,
    cat:document.getElementById('pf-cat').value,
    origin:document.getElementById('pf-origin').value,
    stock,badges:[document.getElementById('pf-badge').value],
    r:4.5,rv:0,
    desc:document.getElementById('pf-desc').value,
    story:document.getElementById('pf-story').value,
    tags:document.getElementById('pf-tags').value.split(',').map(t=>t.trim()).filter(Boolean),
  };
  if(editProdId){
    const idx=products.findIndex(p=>p.id===editProdId);
    if(idx>=0){products[idx]={...products[idx],...data};toast('✅ Đã cập nhật sản phẩm');}
  } else {
    data.id=Date.now();products.push(data);toast('✅ Đã thêm sản phẩm mới');
  }
  saveLS('admin_products',products);
  closeProdModal();renderProducts();updateSidebar();
});

// ── ORDERS ───────────────────────────────────────────
const ORDER_STATUSES=['processing','confirmed','shipped','done','cancelled'];
const STATUS_LABEL={processing:'Đang xử lý',confirmed:'Đã xác nhận',shipped:'Đang giao',done:'Đã giao',cancelled:'Đã hủy'};
const STATUS_CLS={processing:'proc',confirmed:'proc',shipped:'ship',done:'done',cancelled:'cancel'};
function renderOrders(status='all',search=''){
  orders=loadLS('orders',[]);
  // Update tab counts
  document.getElementById('cnt-all').textContent=orders.length;
  document.getElementById('cnt-proc').textContent=orders.filter(o=>o.status==='processing').length;
  document.getElementById('cnt-ship').textContent=orders.filter(o=>o.status==='shipped').length;
  document.getElementById('cnt-done').textContent=orders.filter(o=>o.status==='done').length;
  document.getElementById('cnt-cancel').textContent=orders.filter(o=>o.status==='cancelled').length;
  let list=status==='all'?orders:orders.filter(o=>o.status===status);
  if(search)list=list.filter(o=>o.id.toLowerCase().includes(search)||o.items.toLowerCase().includes(search)||(o.addr||'').toLowerCase().includes(search));
  document.getElementById('orders-tbody').innerHTML=list.length?list.map(o=>`
    <tr>
      <td><strong>${o.id}</strong></td>
      <td style="max-width:200px;font-size:.8rem">${o.items.substring(0,45)}${o.items.length>45?'...':''}</td>
      <td><strong>${vnd(o.total)}</strong></td>
      <td><span style="font-size:.75rem">${o.payment||'COD'}</span></td>
      <td style="font-size:.8rem">${o.date}</td>
      <td><span class="t-status ${STATUS_CLS[o.status]||'proc'}">${STATUS_LABEL[o.status]||o.status}</span></td>
      <td style="white-space:nowrap">
        <button class="btn-icon" title="Xem chi tiết" onclick="viewOrderDetail('${o.id}')">👁️</button>
        <button class="btn-icon" title="Cập nhật trạng thái" onclick="quickStatusUpdate('${o.id}')" style="margin-left:4px">🔄</button>
      </td>
    </tr>`).join(''):'<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted)">Không có đơn hàng</td></tr>';
}
document.querySelectorAll('#order-tabs .admin-tab').forEach(t=>t.addEventListener('click',()=>{
  document.querySelectorAll('#order-tabs .admin-tab').forEach(x=>x.classList.remove('active'));
  t.classList.add('active');orderFilter=t.dataset.status;
  renderOrders(t.dataset.status,document.getElementById('order-search').value);
}));
document.getElementById('order-search').addEventListener('input',e=>renderOrders(orderFilter,e.target.value));
window.viewOrderDetail=function(id){
  orders=loadLS('orders',[]);
  const o=orders.find(x=>x.id===id);if(!o)return;
  editOrderId=id;
  document.getElementById('order-detail-content').innerHTML=`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
      <div class="track-info-box"><h4>Mã Đơn</h4><p style="font-size:1rem;font-weight:800">${o.id}</p></div>
      <div class="track-info-box"><h4>Trạng Thái</h4>
        <select id="od-status" style="padding:6px 10px;border:1.5px solid var(--border);border-radius:8px;font-size:.85rem;font-weight:700;width:100%">
          ${ORDER_STATUSES.map(s=>`<option value="${s}" ${o.status===s?'selected':''}>${STATUS_LABEL[s]}</option>`).join('')}
        </select>
      </div>
      <div class="track-info-box"><h4>Ngày Đặt</h4><p>${o.date}</p></div>
      <div class="track-info-box"><h4>Thanh Toán</h4><p>${o.payment||'COD'}</p></div>
    </div>
    <div class="track-info-box" style="margin-bottom:12px"><h4>Sản Phẩm</h4><p>${o.items}</p><p style="font-size:1rem;font-weight:800;color:var(--primary);margin-top:8px">${vnd(o.total)}</p></div>
    <div class="track-info-box"><h4>Địa Chỉ Giao Hàng</h4><p>${o.addr||'Không có'}</p><p style="margin-top:4px;color:var(--text-muted)">${o.phone?'📞 '+o.phone:''}</p>${o.note?`<p style="margin-top:4px;font-size:.8rem;color:var(--text-muted)">📝 ${o.note}</p>`:''}</div>`;
  document.getElementById('order-modal').classList.add('on');
};
window.quickStatusUpdate=function(id){
  orders=loadLS('orders',[]);
  const o=orders.find(x=>x.id===id);if(!o)return;
  const FLOW={processing:'confirmed',confirmed:'shipped',shipped:'done'};
  const next=FLOW[o.status];
  if(!next){toast('❌ Không thể cập nhật thêm','warn');return;}
  o.status=next;saveLS('orders',orders);renderOrders(orderFilter);toast('✅ Đã chuyển '+id+' → '+STATUS_LABEL[next]);
};
window.closeOrderModal=function(){document.getElementById('order-modal').classList.remove('on');};
document.getElementById('btn-update-status').addEventListener('click',()=>{
  if(!editOrderId)return;
  const newStatus=document.getElementById('od-status')?.value;
  orders=loadLS('orders',[]);
  const o=orders.find(x=>x.id===editOrderId);
  if(o){o.status=newStatus;saveLS('orders',orders);toast('✅ Đã cập nhật '+editOrderId);closeOrderModal();renderOrders(orderFilter);}
});
document.getElementById('btn-export-orders').addEventListener('click',()=>{
  orders=loadLS('orders',[]);
  const csv=['Mã Đơn,Sản Phẩm,Tổng Tiền,Thanh Toán,Ngày,Trạng Thái,Địa Chỉ',...orders.map(o=>`${o.id},"${o.items}",${o.total},${o.payment||'COD'},${o.date},${o.status},"${o.addr||''}"`)].join('\n');
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download='nafarm-orders.csv';a.click();
  toast('📥 Đã xuất file CSV');
});

// ── CATEGORIES ────────────────────────────────────────
function renderCategories(){
  const cats=[...CATEGORIES];
  document.getElementById('cat-grid').innerHTML=cats.map(c=>{
    const count=products.filter(p=>p.cat===c.id).length;
    return `<div class="admin-card" style="padding:20px">
      <div style="font-size:2.5rem;margin-bottom:10px">${c.e}</div>
      <div style="font-weight:800;font-size:1rem;margin-bottom:4px">${c.name}</div>
      <div style="font-size:.82rem;color:var(--text-muted);margin-bottom:12px">${c.desc}</div>
      <div style="display:flex;align-items:center;justify-content:space-between">
        <span class="t-status active">${count} sản phẩm</span>
        <div style="display:flex;gap:6px">
          <button class="btn-icon" title="Sửa">✏️</button>
          <button class="btn-icon" title="Xem sản phẩm" onclick="switchPanel('products')">👁️</button>
        </div>
      </div>
    </div>`;}).join('');
}
document.getElementById('btn-add-cat').addEventListener('click',()=>{
  editCatId=null;
  document.getElementById('cat-modal-title').textContent='🎯 Thêm Danh Mục Mới';
  ['cf-name','cf-emoji','cf-slug','cf-desc'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('cat-modal').classList.add('on');
});

// ── CUSTOMERS ─────────────────────────────────────────
function renderCustomers(){
  orders=loadLS('orders',[]);
  const map={};
  orders.forEach(o=>{
    const key=o.userId||o.phone||'Khách';
    if(!map[key])map[key]={id:key,orders:[],total:0};
    map[key].orders.push(o);map[key].total+=o.total;
  });
  const clist=Object.values(map);
  document.getElementById('customers-tbody').innerHTML=clist.length?clist.map((c,i)=>`
    <tr>
      <td>${i+1}</td>
      <td><div style="font-weight:700">${c.id==='Khách'?'Khách Vãng Lai':c.id}</div></td>
      <td><span class="badge-count blue">${c.orders.length}</span></td>
      <td><strong>${vnd(c.total)}</strong></td>
      <td style="font-size:.8rem">${c.orders[c.orders.length-1]?.date||'–'}</td>
      <td><button class="btn btn-ghost" style="font-size:.76rem;padding:5px 10px" onclick="switchPanel('orders')">Xem Đơn</button></td>
    </tr>`).join(''):'<tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text-muted)">Chưa có khách hàng</td></tr>';
}

// ── ANALYTICS ─────────────────────────────────────────
function renderAnalytics(){
  orders=loadLS('orders',[]);
  const totalRev=orders.filter(o=>o.status==='done').reduce((s,o)=>s+o.total,0);
  const avg=orders.length?Math.round(totalRev/Math.max(orders.filter(o=>o.status==='done').length,1)):0;
  document.getElementById('analytics-stats').innerHTML=`
    <div class="stat-card"><div class="stat-card-icon green">💰</div><div><div class="stat-card-val">${vnd(totalRev)}</div><div class="stat-card-lbl">Doanh Thu Thực Nhận</div></div></div>
    <div class="stat-card"><div class="stat-card-icon brown">📦</div><div><div class="stat-card-val">${orders.length}</div><div class="stat-card-lbl">Tổng Đơn</div></div></div>
    <div class="stat-card"><div class="stat-card-icon blue">💳</div><div><div class="stat-card-val">${vnd(avg)}</div><div class="stat-card-lbl">Giá Trị Đơn TB</div></div></div>
    <div class="stat-card"><div class="stat-card-icon yellow">✅</div><div><div class="stat-card-val">${orders.filter(o=>o.status==='done').length}</div><div class="stat-card-lbl">Đơn Thành Công</div></div></div>`;
  // Top 5
  const top5=products.slice().sort((a,b)=>b.rv-a.rv).slice(0,5);
  document.getElementById('top5-list').innerHTML=top5.map((p,i)=>`
    <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border)">
      <div style="font-size:1.2rem;width:30px;text-align:center">${['🥇','🥈','🥉','4️⃣','5️⃣'][i]}</div>
      <div style="font-size:1.3rem">${p.e}</div>
      <div style="flex:1"><div style="font-weight:700;font-size:.84rem">${p.name}</div><div style="font-size:.72rem;color:var(--text-muted)">${p.rv} đánh giá</div></div>
      <div style="font-weight:800;font-size:.9rem;color:var(--primary)">${vnd(p.price)}</div>
    </div>`).join('');
  // Payment chart
  const payMap={};orders.forEach(o=>payMap[o.payment||'COD']=(payMap[o.payment||'COD']||0)+1);
  const total=orders.length||1;
  document.getElementById('payment-chart').innerHTML=Object.entries(payMap).map(([k,v])=>`
    <div style="margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;font-size:.82rem;font-weight:700;margin-bottom:4px"><span>${k}</span><span>${v} đơn (${Math.round(v/total*100)}%)</span></div>
      <div style="height:8px;background:var(--border);border-radius:99px;overflow:hidden"><div style="height:100%;background:var(--primary);border-radius:99px;width:${Math.round(v/total*100)}%;transition:width .6s"></div></div>
    </div>`).join('')||'<p style="color:var(--text-muted)">Chưa có dữ liệu</p>';
}

// Close modals on overlay click
document.getElementById('prod-modal').addEventListener('click',e=>{if(e.target===document.getElementById('prod-modal'))closeProdModal();});
document.getElementById('order-modal').addEventListener('click',e=>{if(e.target===document.getElementById('order-modal'))closeOrderModal();});
document.getElementById('cat-modal').addEventListener('click',e=>{if(e.target===document.getElementById('cat-modal'))closeCatModal();});

// Category modal functions
window.closeCatModal=function(){document.getElementById('cat-modal').classList.remove('on');};
document.getElementById('cf-name').addEventListener('input',e=>{
  const slug=e.target.value.trim().toLowerCase().replace(/\s+/g,'-').replace(/[^\w-]/g,'');
  document.getElementById('cf-slug').value=slug;
});
document.getElementById('btn-save-category').addEventListener('click',()=>{
  const name=document.getElementById('cf-name').value.trim();
  const emoji=document.getElementById('cf-emoji').value.trim();
  const slug=document.getElementById('cf-slug').value.trim();
  const desc=document.getElementById('cf-desc').value.trim();
  if(!name||!emoji||!slug||!desc){toast('⚠️ Điền đủ thông tin bắt buộc','warn');return;}
  if(CATEGORIES.find(c=>c.id===slug)&&!editCatId){toast('⚠️ Slug này đã tồn tại','warn');return;}
  const newCat={id:slug,name,e:emoji,desc};
  if(editCatId){
    const idx=CATEGORIES.findIndex(c=>c.id===editCatId);
    if(idx>=0){CATEGORIES[idx]=newCat;toast('✅ Đã cập nhật danh mục');}
  } else {
    CATEGORIES.push(newCat);toast('✅ Đã thêm danh mục mới');
  }
  closeCatModal();renderCategories();
});

// Init
document.getElementById('today-date').textContent=new Date().toLocaleDateString('vi-VN',{weekday:'long',day:'2-digit',month:'2-digit',year:'numeric'});
const user=loadLS('user',null);
if(user)document.getElementById('admin-user-info').textContent='👨‍💼 '+user.name;
updateSidebar();
renderDashboard();
})();
</script>
</body>
</html>
