<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Admin Dashboard – NaFarm</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>"/>
  <link rel="stylesheet" href="../../css/style.css"/>
  <style>
    :root { --nav-h: 60px; }
    body { background: #F0F4F0; }
    .admin-layout { display: flex; min-height: 100vh; padding-top: var(--nav-h); }

    /* Sidebar */
    .sidebar {
      width: 240px; background: var(--green-900); flex-shrink: 0;
      position: fixed; top: var(--nav-h); bottom: 0; left: 0;
      overflow-y: auto; z-index: 100;
      display: flex; flex-direction: column;
    }
    .sidebar-logo { padding: 20px 20px 10px; }
    .sidebar-logo p { color: rgba(255,255,255,.5); font-size: .72rem; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 4px; }
    .sidebar-nav { flex: 1; padding: 10px 12px; }
    .s-section { font-size: .64rem; font-weight: 800; color: rgba(255,255,255,.35); text-transform: uppercase; letter-spacing: 2px; padding: 14px 8px 6px; }
    .s-link {
      display: flex; align-items: center; gap: 10px; padding: 10px 12px;
      border-radius: 10px; color: rgba(255,255,255,.65); font-size: .85rem; font-weight: 600;
      cursor: pointer; transition: all var(--t-1); margin-bottom: 2px; border: none; background: none; width: 100%; text-align: left;
    }
    .s-link:hover { background: rgba(255,255,255,.1); color: var(--white); }
    .s-link.active { background: rgba(255,255,255,.15); color: var(--white); }
    .s-link .s-badge { margin-left: auto; background: var(--secondary); color: var(--white); padding: 2px 8px; border-radius: 99px; font-size: .64rem; font-weight: 900; }

    /* Main */
    .admin-main { margin-left: 240px; flex: 1; padding: 28px; min-height: calc(100vh - var(--nav-h)); }

    /* Top Bar */
    .admin-topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 14px; }
    .admin-topbar h1 { font-family: var(--font-display); font-size: 1.6rem; color: var(--text-primary); }
    .admin-topbar p { font-size: .84rem; color: var(--text-muted); margin-top: 2px; }
    .topbar-actions { display: flex; gap: 10px; }

    /* Stats Cards */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(220px,1fr)); gap: 18px; margin-bottom: 28px; }
    .stat-card {
      background: var(--white); border-radius: 16px; padding: 22px 20px;
      border: 1.5px solid var(--border); transition: all var(--t-2);
      display: flex; align-items: flex-start; gap: 16px;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
    .stat-card-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; flex-shrink: 0; }
    .stat-card-icon.green  { background: var(--green-100); }
    .stat-card-icon.brown  { background: var(--brown-100); }
    .stat-card-icon.blue   { background: var(--pastel-sky); }
    .stat-card-icon.yellow { background: var(--pastel-yellow); }
    .stat-card-val { font-family: var(--font-display); font-size: 1.8rem; font-weight: 700; color: var(--text-primary); line-height: 1; }
    .stat-card-lbl { font-size: .78rem; color: var(--text-muted); margin-top: 4px; }
    .stat-card-trend { font-size: .74rem; font-weight: 700; margin-top: 6px; }
    .stat-card-trend.up   { color: var(--primary); }
    .stat-card-trend.down { color: var(--danger); }

    /* Grid 2 cols */
    .grid-2 { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; margin-bottom: 20px; }
    @media(max-width:900px) { .grid-2 { grid-template-columns: 1fr; } }

    /* Cards */
    .admin-card { background: var(--white); border-radius: 16px; padding: 22px; border: 1.5px solid var(--border); }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .card-title { font-weight: 800; font-size: .96rem; }
    .card-badge { padding: 3px 12px; border-radius: 99px; font-size: .72rem; font-weight: 800; background: var(--green-100); color: var(--green-700); }

    /* Table */
    .admin-table { width: 100%; border-collapse: collapse; }
    .admin-table th { font-size: .72rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
    .admin-table td { padding: 12px 12px; font-size: .84rem; border-bottom: 1px solid rgba(0,0,0,.04); vertical-align: middle; }
    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table tr:hover td { background: var(--green-50); }
    .t-product { display: flex; align-items: center; gap: 10px; }
    .t-emoji { width: 36px; height: 36px; background: var(--green-50); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .t-name { font-weight: 700; font-size: .84rem; }
    .t-origin { font-size: .72rem; color: var(--text-muted); }
    .t-status { padding: 3px 10px; border-radius: 99px; font-size: .68rem; font-weight: 800; }
    .t-status.active { background: var(--green-100); color: var(--green-700); }
    .t-status.low    { background: var(--pastel-yellow); color: #8a6010; }
    .t-status.out    { background: #ffe0e0; color: var(--danger); }

    /* Bar Chart */
    .chart-bars { display: flex; align-items: flex-end; gap: 8px; height: 120px; padding-top: 10px; }
    .chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .chart-bar { width: 100%; background: var(--green-200); border-radius: 6px 6px 0 0; transition: all .3s; position: relative; min-height: 8px; }
    .chart-bar:hover { background: var(--primary); }
    .chart-bar-lbl { font-size: .66rem; color: var(--text-muted); font-weight: 700; }
    .chart-bar-val { font-size: .62rem; color: var(--text-muted); }

    /* Orders List */
    .o-list { display: flex; flex-direction: column; gap: 10px; }
    .o-item { display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--bg); border-radius: 10px; border: 1px solid var(--border); }
    .o-item-id { font-size: .78rem; font-weight: 800; color: var(--text-secondary); min-width: 100px; }
    .o-item-info { flex: 1; }
    .o-item-name { font-size: .84rem; font-weight: 700; }
    .o-item-date { font-size: .72rem; color: var(--text-muted); }
    .o-item-price { font-family: var(--font-display); font-weight: 700; color: var(--secondary); font-size: .96rem; flex-shrink: 0; }
    .o-item-status { flex-shrink: 0; }

    /* Top products */
    .top-prod-list { display: flex; flex-direction: column; gap: 12px; }
    .top-prod-item { display: flex; align-items: center; gap: 12px; }
    .tp-rank { width: 24px; height: 24px; border-radius: 50%; background: var(--green-100); display: flex; align-items: center; justify-content: center; font-size: .72rem; font-weight: 900; color: var(--green-700); flex-shrink: 0; }
    .tp-emoji { font-size: 1.4rem; width: 36px; text-align: center; flex-shrink: 0; }
    .tp-info { flex: 1; }
    .tp-name { font-size: .84rem; font-weight: 700; }
    .tp-sales { font-size: .72rem; color: var(--text-muted); }
    .tp-val { font-family: var(--font-display); font-size: .9rem; font-weight: 700; color: var(--secondary); flex-shrink: 0; }
    .tp-bar-wrap { width: 60px; height: 6px; background: var(--green-100); border-radius: 99px; overflow: hidden; flex-shrink: 0; }
    .tp-bar { height: 100%; background: var(--primary); border-radius: 99px; }

    @media(max-width:700px) { .sidebar { display: none; } .admin-main { margin-left: 0; } }
  </style>
</head>
<body>

<!-- Simple admin nav -->
<nav class="nav" style="background:var(--green-900);border-bottom-color:rgba(255,255,255,.1)">
  <div class="nav-inner">
    <a href="../../index.html" class="logo">
      <div class="logo-mark">🌿</div>
      <div class="logo-text"><span class="brand" style="color:var(--white)">NaFarm</span><span class="tagline" style="color:rgba(255,255,255,.4)">Admin Dashboard</span></div>
    </a>
    <div style="flex:1"></div>
    <div style="display:flex;align-items:center;gap:12px">
      <span style="color:rgba(255,255,255,.6);font-size:.84rem">👤 Admin</span>
      <a href="../../index.html" class="btn btn-sm" style="background:rgba(255,255,255,.15);color:var(--white)">← Về Trang Chủ</a>
    </div>
  </div>
</nav>

<div class="admin-layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <p>Bảng Điều Khiển</p>
    </div>
    <nav class="sidebar-nav">
      <div class="s-section">Tổng Quan</div>
      <button class="s-link active">📊 Dashboard</button>
