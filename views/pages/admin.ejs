          </div>
          <div class="top-prod-item">
            <div class="tp-rank">3</div><div class="tp-emoji">🍓</div>
            <div class="tp-info"><div class="tp-name">Dâu Tây Sấy Giòn</div><div class="tp-sales">89 đơn</div></div>
            <div class="tp-val">8.2M</div>
            <div class="tp-bar-wrap"><div class="tp-bar" style="width:72%"></div></div>
          </div>
          <div class="top-prod-item">
            <div class="tp-rank">4</div><div class="tp-emoji">🌰</div>
            <div class="tp-info"><div class="tp-name">Macadamia Úc</div><div class="tp-sales">78 đơn</div></div>
