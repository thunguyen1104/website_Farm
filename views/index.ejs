<!-- ═══════════════════════════════════════════════════
     AUTH MODAL  (Bước 2 – OAuth + Email/SĐT)
═══════════════════════════════════════════════════ -->
<div class="auth-overlay">
  <div class="auth-box">
    <div class="auth-top">
      <div class="auth-logo">🌿</div>
      <h2>Chào Mừng Đến NaFarm</h2>
      <p>Đăng nhập để mua hàng, xem đơn và nhận ưu đãi độc quyền</p>
      <div class="auth-tabs">
        <button class="a-tab on" data-t="login">Đăng Nhập</button>
        <button class="a-tab" data-t="register">Đăng Ký</button>
      </div>
    </div>
    <div class="auth-body">
      <!-- Login -->
      <div class="a-pane on" data-p="login">
        <form id="login-form">
          <div class="f-group"><label class="f-label">Email hoặc Số Điện Thoại</label><input id="l-email" type="text" class="f-input" placeholder="email@example.com"/></div>
          <div class="f-group"><label class="f-label">Mật Khẩu</label><input id="l-pass" type="password" class="f-input" placeholder="••••••••"/></div>
          <button type="submit" class="btn btn-primary btn-block" style="margin-bottom:10px">🌿 Đăng Nhập</button>
          <div style="text-align:center;font-size:.76rem;color:var(--text-muted)"><a href="#" style="color:var(--primary)">Quên mật khẩu?</a></div>
        </form>
        <div class="auth-or"><span>hoặc đăng nhập nhanh với</span></div>
        <div class="social-btns">
          <button class="s-btn" data-p="Google">🔵 Google</button>
          <button class="s-btn" data-p="Facebook">📘 Facebook</button>
        </div>
      </div>
      <!-- Register -->
      <div class="a-pane" data-p="register">
        <form id="reg-form">
          <div class="f-group"><label class="f-label">Họ và Tên</label><input id="r-name" type="text" class="f-input" placeholder="Nguyễn Văn A"/></div>
          <div class="f-group"><label class="f-label">Email</label><input id="r-email" type="email" class="f-input" placeholder="email@example.com"/></div>
          <div class="f-group"><label class="f-label">Mật Khẩu</label><input id="r-pass" type="password" class="f-input" placeholder="Tối thiểu 8 ký tự"/></div>
          <button type="submit" class="btn btn-secondary btn-block">🎉 Tạo Tài Khoản</button>
        </form>
        <div class="auth-or"><span>hoặc đăng ký nhanh với</span></div>
        <div class="social-btns">
          <button class="s-btn" data-p="Google">🔵 Google</button>
          <button class="s-btn" data-p="Facebook">📘 Facebook</button>
        </div>
      </div>
    </div>
  </div>
</div>

